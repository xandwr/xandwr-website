---
export interface CardItem {
  href: string;
  title: string;
  date: Date;
  description: string;
}

interface Props {
  items: CardItem[];
  emptyText?: string;
}

const { items, emptyText = "the empty void of nothing" } = Astro.props;
---

{
  items.length === 0 ? (
    <p class="text-primary text-sm">{emptyText}</p>
  ) : (
    <div class="flex flex-col gap-y-2 h-full">
      {items.map((item) => (
        <a
          href={item.href}
          class="card-link flex flex-col gap-1 border hover:shadow-secondary/10 shadow-lg transition-all border-secondary rounded-lg bg-tertiary/5 hover:bg-tertiary/20"
        >
          <div class="flex items-baseline justify-between">
            <div class="flex flex-col items-start justify-between h-full w-full gap-y-0 bg-tertiary/10 rounded-l py-2 px-2">
              <span class="text-primary font-bold underline uppercase text-2xl">
                {item.title}
              </span>
              <p class="text-tertiary text-base m-0">{item.description}</p>
            </div>

            <time
              class="text-secondary self-start py-1 px-2 bg-secondary/20 border-l border-secondary/33 rounded-tr h-full font-digit-bold"
              datetime={item.date.toISOString()}
            >
              {item.date.toISOString().slice(0, 10)}
            </time>
          </div>
        </a>
      ))}
    </div>
  )
}

<style>
  .card-link,
  .card-link:hover,
  .card-link:focus,
  .card-link:focus-visible,
  .card-link:active {
    text-decoration: none;
  }
</style>
