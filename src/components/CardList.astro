---
export interface CardItem {
  href: string;
  title: string;
  date: Date;
  description: string;
}

interface Props {
  items: CardItem[];
  emptyText?: string;
}

const { items, emptyText = "Nothing here yet." } = Astro.props;
---

{
  items.length === 0 ? (
    <p>{emptyText}</p>
  ) : (
    <ul class="entry-list">
      {items.map((item) => (
        <li>
          <h2>
            <a href={item.href}>{item.title}</a>
          </h2>
          <p class="meta">
            <time datetime={item.date.toISOString()}>
              {item.date.toISOString().slice(0, 10)}
            </time>
            {item.description && <> - {item.description}</>}
          </p>
        </li>
      ))}
    </ul>
  )
}
