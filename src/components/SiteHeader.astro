---
const { pathname } = Astro.url;
const isActive = (href: string) =>
  href === "/" ? pathname === "/" : pathname.startsWith(href);

const links = [
  { href: "/", label: "home" },
  { href: "/posts/", label: "posts" },
  { href: "/projects/", label: "projects" },
];
---

<header class="h-min flex flex-row">
  <nav class="w-full text-muted text-sm flex flex-col gap-y-2">
    <a
      href="/"
      class="nav-link text-4xl tracking-wide font-lighter text-fg font-special"
      >xandwr</a
    >
    <div class="flex gap-x-4 text-lg">
      {
        links.map((link, i) => (
          <>
            <a
              href={link.href}
              class:list={[
                "nav-link",
                isActive(link.href) ? "text-primary" : "text-muted",
              ]}
            >
              {link.label}
            </a>
            {i < links.length - 1 && <span class="text-muted">/</span>}
          </>
        ))
      }
    </div>
  </nav>

  <div
    class="flex flex-col items-start justify-start bg-bg/33 border border-primary/50 py-2 px-6 rounded-xl h-min"
  >
    <label for="theme-selector" class="text-secondary">Site Theme:</label>
    <select name="theme-selector" id="theme-selector" class="text-primary bg-transparent">
      <option value="normal-light">Normal — Light</option>
      <option value="normal-dark">Normal — Dark</option>
      <option value="amber-phosphor">Amber Phosphor</option>
    </select>
  </div>
</header>

<script>
  function wireThemeSelector() {
    const sel = document.getElementById("theme-selector") as HTMLSelectElement | null;
    if (!sel) return;

    const current = document.documentElement.getAttribute("data-theme") || "normal-light";
    sel.value = current;

    sel.onchange = () => {
      const next = sel.value;
      document.documentElement.setAttribute("data-theme", next);
      try {
        localStorage.setItem("theme", next);
      } catch (_) {}
      document.dispatchEvent(new CustomEvent("theme:changed", { detail: next }));
    };
  }

  wireThemeSelector();
  document.addEventListener("astro:after-swap", wireThemeSelector);
</script>

<style>
  .nav-link,
  .nav-link:visited {
    color: inherit;
  }
  .nav-link.text-fg,
  .nav-link.text-fg:visited {
    color: var(--color-fg);
  }
  .nav-link.text-primary,
  .nav-link.text-primary:visited {
    color: var(--color-primary);
  }
  .nav-link.text-muted,
  .nav-link.text-muted:visited {
    color: var(--color-muted);
  }
</style>
