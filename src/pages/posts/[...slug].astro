---
import { getCollection, render, type CollectionEntry } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageTitle from "../../components/PageTitle.astro";

export const prerender = true;

export async function getStaticPaths() {
  const posts = await getCollection("posts", ({ data }) => !data.draft);
  return posts.map((post) => ({ params: { slug: post.id }, props: { post } }));
}

const { post } = Astro.props as { post: CollectionEntry<"posts"> };
const { Content } = await render(post);
const updated =
  post.data.updated &&
  post.data.updated.getTime() !== post.data.created.getTime()
    ? post.data.updated
    : null;
---

<BaseLayout title={post.data.title} description={post.data.description}>
  <PageTitle title={post.data.title}>
    <Fragment slot="meta">
      <time datetime={post.data.created.toISOString()}>
        {post.data.created.toISOString().slice(0, 10)}
      </time>
      {updated && <> · updated {updated.toISOString().slice(0, 10)}</>}
    </Fragment>
  </PageTitle>
  <div class="prose">
    <Content />
  </div>
</BaseLayout>
