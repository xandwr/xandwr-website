---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export const prerender = true;

export async function getStaticPaths() {
  const posts = await getCollection('posts', ({ data }) => !data.draft);
  return posts.map((post) => ({ params: { slug: post.id }, props: { post } }));
}

const { post } = Astro.props as { post: CollectionEntry<'posts'> };
const { Content } = await render(post);
---

<BaseLayout title={post.data.title} description={post.data.description}>
  <h1>{post.data.title}</h1>
  <p class="text-muted text-sm -mt-2">
    <time datetime={post.data.created.toISOString()}>
      {post.data.created.toISOString().slice(0, 10)}
    </time>
    {post.data.updated && post.data.updated.getTime() !== post.data.created.getTime() && (
      <> · updated {post.data.updated.toISOString().slice(0, 10)}</>
    )}
  </p>
  <Content />
</BaseLayout>
