---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import CardList from "../../components/CardList.astro";

export const prerender = true;

const posts = (await getCollection("posts", ({ data }) => !data.draft))
  .sort((a, b) => b.data.created.getTime() - a.data.created.getTime())
  .map((post) => ({
    href: `/posts/${post.id}/`,
    title: post.data.title,
    date: post.data.created,
    description: post.data.description,
  }));
---

<BaseLayout title="posts" description="xander's writing">
  <h1 class="text-3xl mt-4 mb-2">Posts</h1>
  <hr class="border-0 border-t border-rule/50 my-4 h-min" />
  <CardList items={posts} />
</BaseLayout>
