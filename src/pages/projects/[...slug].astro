---
import { getCollection, render, type CollectionEntry } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageTitle from "../../components/PageTitle.astro";

export const prerender = true;

export async function getStaticPaths() {
  const projects = await getCollection("projects", ({ data }) => !data.draft);
  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props as { project: CollectionEntry<"projects"> };
const { Content } = await render(project);
const updated =
  project.data.updated &&
  project.data.updated.getTime() !== project.data.created.getTime()
    ? project.data.updated
    : null;
---

<BaseLayout title={project.data.title} description={project.data.description}>
  <PageTitle title={project.data.title}>
    <Fragment slot="meta">
      <time datetime={project.data.created.toISOString()}>
        {project.data.created.toISOString().slice(0, 10)}
      </time>
      {updated && <> · updated {updated.toISOString().slice(0, 10)}</>}
      {project.data.repo && <> · <a href={project.data.repo}>repo</a></>}
      {project.data.url && <> · <a href={project.data.url}>live</a></>}
    </Fragment>
  </PageTitle>
  <div class="prose">
    <Content />
  </div>
</BaseLayout>
