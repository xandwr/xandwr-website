---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const { title, description } = Astro.props;
const fullTitle = title ? `${title} — xandwr` : "xandwr";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.ico" />
    <link rel="icon" href="/favicon.ico" />
    <title>{fullTitle}</title>
    {description && <meta name="description" content={description} />}
    <meta name="generator" content={Astro.generator} />
  </head>
  <body
    class="flex flex-col justify-between bg-black/20 h-screen max-w-xl mx-auto px-8 py-8 min-h-screen"
  >
    <header class="h-min">
      <nav class="text-muted text-sm flex flex-col gap-y-2">
        <a href="/" class="text-xl font-semibold text-fg">xandwr</a>
        <div class="flex gap-x-4">
          <a href="/">home</a> /
          <a href="/posts/">posts</a> /
          <a href="/projects/">projects</a>
        </div>
      </nav>
    </header>

    <hr class="border-0 border-t border-rule/50 mt-8" />

    <main class="h-full">
      <slot />
    </main>

    <footer class="mt-3">
      <hr class="border-0 border-t border-rule/50 my-3" />

      <p class="text-muted/33 text-sm flex justify-between">
        <a href="https://github.com/xandwr">github (@xandwr)</a><span
          >© {new Date().getFullYear()}</span
        >
      </p>
    </footer>
  </body>
</html>
