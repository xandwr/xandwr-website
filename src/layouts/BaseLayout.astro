---
import "../styles/global.css";
import { ClientRouter } from "astro:transitions";

interface Props {
  title?: string;
  description?: string;
}

const { title, description } = Astro.props;
const fullTitle = title ? `${title} — xandwr` : "xandwr";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.ico" />
    <link rel="icon" href="/favicon.ico" />
    <title>{fullTitle}</title>
    {description && <meta name="description" content={description} />}
    <meta name="generator" content={Astro.generator} />
    <ClientRouter />
  </head>
  <body
    class="flex flex-col justify-between border-x shadow-xl shadow-black border-fg/20 h-screen max-w-xl mx-auto px-8 py-8 min-h-screen"
  >
    <canvas id="bg-canvas" transition:persist></canvas>

    <header class="h-min">
      <nav class="text-muted text-sm flex flex-col gap-y-2">
        <a href="/" class="text-xl font-semibold text-fg">xandwr</a>
        <div class="flex gap-x-4">
          <a href="/">home</a> /
          <a href="/posts/">posts</a> /
          <a href="/projects/">projects</a>
        </div>
      </nav>
    </header>

    <hr class="border-0 border-t border-rule/50 mt-8" />

    <main class="h-full">
      <slot />
    </main>

    <footer class="mt-3">
      <hr class="border-0 border-t border-rule/50 my-3" />

      <p class="text-muted/33 text-sm flex justify-between">
        <a href="https://github.com/xandwr">github (@xandwr)</a><span
          >© {new Date().getFullYear()}</span
        >
      </p>
    </footer>

    <script>
      import vertSrc from "../shaders/background.vert.glsl?raw";
      import fragSrc from "../shaders/background.frag.glsl?raw";

      const canvas = document.getElementById("bg-canvas") as HTMLCanvasElement & {
        __shaderInit?: boolean;
      };
      const gl = canvas?.__shaderInit
        ? null
        : canvas?.getContext("webgl2", { antialias: false, premultipliedAlpha: false });

      if (gl) {
        canvas.__shaderInit = true;

        const compile = (type: number, src: string) => {
          const s = gl.createShader(type)!;
          gl.shaderSource(s, src);
          gl.compileShader(s);
          if (!gl.getShaderParameter(s, gl.COMPILE_STATUS)) {
            console.error(gl.getShaderInfoLog(s));
          }
          return s;
        };

        const prog = gl.createProgram()!;
        gl.attachShader(prog, compile(gl.VERTEX_SHADER, vertSrc));
        gl.attachShader(prog, compile(gl.FRAGMENT_SHADER, fragSrc));
        gl.linkProgram(prog);
        gl.useProgram(prog);

        const buf = gl.createBuffer();
        gl.bindBuffer(gl.ARRAY_BUFFER, buf);
        gl.bufferData(
          gl.ARRAY_BUFFER,
          new Float32Array([-1, -1, 3, -1, -1, 3]),
          gl.STATIC_DRAW
        );
        const loc = gl.getAttribLocation(prog, "a_pos");
        gl.enableVertexAttribArray(loc);
        gl.vertexAttribPointer(loc, 2, gl.FLOAT, false, 0, 0);

        const uRes = gl.getUniformLocation(prog, "iResolution");
        const uTime = gl.getUniformLocation(prog, "iTime");

        const resize = () => {
          const dpr = Math.min(window.devicePixelRatio || 1, 2);
          const w = Math.floor(innerWidth * dpr);
          const h = Math.floor(innerHeight * dpr);
          if (canvas.width !== w || canvas.height !== h) {
            canvas.width = w;
            canvas.height = h;
            gl.viewport(0, 0, w, h);
          }
        };
        resize();
        addEventListener("resize", resize);

        const start = performance.now();
        const frame = () => {
          resize();
          gl.uniform2f(uRes, canvas.width, canvas.height);
          gl.uniform1f(uTime, (performance.now() - start) / 1000);
          gl.drawArrays(gl.TRIANGLES, 0, 3);
          requestAnimationFrame(frame);
        };
        requestAnimationFrame(frame);
      }
    </script>
  </body>
</html>
